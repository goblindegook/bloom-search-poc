    "autoprefixer": "^10.4.14",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.9.3",
    "vite": "^4.3.9"
  },
  "dependencies": {
    "@faker-js/faker": "^9.5.0",
    "@msgpack/msgpack": "^3.1.3",
    "@pacote/array": "^0.10.1",
    "@pacote/bloom-search": "^0.18.2",
    "@pacote/xxhash": "^0.5.1",
    "@preact/signals": "^1.1.3",
    "chalk": "^5.2.0",
    "clsx": "^2.1.1",
    "elasticlunr": "^0.9.5",
    "fuse.js": "^7.3.0",
    "gzip-size": "^7.0.0",
    "lunr": "^2.3.9",
